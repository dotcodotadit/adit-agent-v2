# ==============================================================================
# Adit-Agent — environment configuration template
#
# HOW TO USE
# ----------
# 1. Copy this file:    cp .env.example .env
# 2. Fill in the required values marked  ← REQUIRED  below.
# 3. Start the bot:     python -m app.main
#
# All values are loaded by app/config.py (pydantic-settings).
# Precedence: environment variables > .env file > built-in defaults.
# NEVER commit your real .env — it is listed in .gitignore.
# ==============================================================================


# ==============================================================================
# CORE APPLICATION
# ==============================================================================

APP_NAME=Adit-Agent

# Log verbosity: debug | info | warning | error | critical
LOG_LEVEL=info

# Runtime environment tag (affects error verbosity, future feature flags).
# development | staging | production
ENVIRONMENT=development

# Root data directory — all sub-directories below are relative to this.
# Change this to an absolute path if you want data outside the repo.
DATA_DIR=data

# Where Telegram file downloads land.
UPLOAD_DIR=data/uploads

# Temporary / generated assets (keyframes, screenshots, etc.).
CACHE_DIR=data/cache

# ChromaDB persistent storage.
VECTOR_STORE_DIR=data/vector_store


# ==============================================================================
# TELEGRAM BOT                                                     ← REQUIRED
# ==============================================================================

# How to get a bot token:
#   1. Open Telegram and chat with @BotFather.
#   2. Send /newbot and follow the prompts.
#   3. Copy the token (looks like  123456789:ABCdef…) and paste below.
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz1234567890

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow ALL users (not recommended for public bots).
#
# How to find your user ID:
#   Chat with @userinfobot or @RawDataBot — they reply with your numeric ID.
#
# Example:  TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=

# Admin IDs can run privileged commands (e.g. /stats, /dev mode).
# Typically just the bot owner's ID.
TELEGRAM_ADMIN_USER_IDS=


# ==============================================================================
# LLM PROVIDERS
# ==============================================================================
# Adit-Agent uses an OpenAI-compatible HTTP API, so any provider that exposes
# the /chat/completions endpoint works (OpenAI, Azure OpenAI, Together AI,
# Groq, Ollama, LiteLLM, etc.).
#
# FAILOVER CHAIN
# Providers are tried in the order listed in LLM_PROVIDER_PRIORITY.
# The first one with a non-empty API key and a healthy response wins.
# You only need to configure ONE provider to get started.
#
# QUICK START — OpenAI
# Point the first slot at OpenAI:
#   FREEMODEL_API_KEY=sk-…your-openai-key…
#   FREEMODEL_BASE_URL=https://api.openai.com/v1
#   LLM_DEFAULT_MODEL=gpt-4o-mini

LLM_PROVIDER_PRIORITY=freemodel,aerolink,zerog,zyloo

# Model name sent to the provider with every request.
# Must be a model the active provider supports.
# Examples: gpt-4o-mini  |  gpt-4o  |  claude-3-haiku  |  llama-3-8b-instruct
LLM_DEFAULT_MODEL=gpt-4o-mini

# Per-request HTTP timeout in seconds. Increase for slow providers / large models.
LLM_REQUEST_TIMEOUT=60

# How many times to retry a failed provider call before trying the next provider.
LLM_MAX_RETRIES=3

# Sampling temperature (0.0 = deterministic, 1.0 = very creative).
LLM_TEMPERATURE=0.7

# ------------------------------------------------------------------------------
# Provider slots — fill in any ONE (or more for failover).
# API key:  required for authentication.
# Base URL: root of the OpenAI-compatible REST API (no trailing slash).
# ------------------------------------------------------------------------------

# Slot 1 — primary provider (highest priority)
FREEMODEL_API_KEY=
FREEMODEL_BASE_URL=https://api.freemodel.dev/v1

# Slot 2 — first fallback
AEROLINK_API_KEY=
AEROLINK_BASE_URL=https://capi.aerolink.lat/

# Slot 3 — second fallback
ZEROG_API_KEY=
ZEROG_BASE_URL=https://router-api.0g.ai/v1

# Slot 4 — last resort fallback
ZYLOO_API_KEY=
ZYLOO_BASE_URL=


# ==============================================================================
# EMBEDDINGS & VECTOR STORE (optional — enables long-term memory)
# ==============================================================================
# Embeddings require an API key in one of the provider slots above that also
# supports the /embeddings endpoint (e.g. OpenAI, Together AI).
# If no embedding provider is available the agent falls back to
# importance-ranked relational memory (no semantic recall).

# Model used to embed memories for semantic search.
# OpenAI options: text-embedding-3-small (1536d) | text-embedding-3-large (3072d)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ChromaDB collection name.  Change this if you want separate memory namespaces
# (e.g. per-deployment or per-user).
CHROMA_COLLECTION=adit_long_term


# ==============================================================================
# DATABASE
# ==============================================================================
# Default: local SQLite (no setup required, good for single-user bots).
# For production or multi-instance deployments use PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/adit_agent
#
# Note: the SQLite path is relative to the project root.
DATABASE_URL=sqlite+aiosqlite:///data/db.sqlite3

# Echo all SQL statements to the log — useful for debugging schema issues.
DATABASE_ECHO=false


# ==============================================================================
# AGENT BEHAVIOR
# ==============================================================================

# Maximum number of ReAct loop iterations per request.
# Higher = more thorough but slower and more expensive.
AGENT_MAX_STEPS=12

# Maximum tokens in a single completion response.
AGENT_MAX_TOKENS=4096

# How many recent messages to include as short-term memory context.
SHORT_TERM_WINDOW=20

# Enable the task-decomposition planner stage before execution.
# Disable for faster, single-step responses on simple queries.
ENABLE_PLANNER=true


# ==============================================================================
# SAFETY & SANDBOX
# ==============================================================================

# When true, tools marked dangerous=True show an inline "Approve / Deny"
# button in Telegram before they execute.
REQUIRE_TOOL_CONFIRMATION=true

# Comma-separated list of tool names that are always treated as dangerous
# regardless of the flag above.
DANGEROUS_TOOLS=shell,write_file,browser,process

# Filesystem root that the shell, write_file, and search_files tools are
# restricted to. Paths outside this directory are rejected.
# Use an absolute path to be explicit:  /home/user/adit-sandbox
SANDBOX_ROOT=data/sandbox


# ==============================================================================
# RATE LIMITING (inbound flood control, per user)
# ==============================================================================
# Throttles how fast a single user may send messages, protecting the bot and
# your LLM credits from floods. Admins (TELEGRAM_ADMIN_USER_IDS) bypass this.
# Distinct from PTB's outbound AIORateLimiter.

# Master switch for the inbound rate limiter.
RATE_LIMIT_ENABLED=true

# Maximum messages a single user may send within the rolling window below.
RATE_LIMIT_MAX_MESSAGES=5

# Length of the rolling window in seconds.
RATE_LIMIT_WINDOW_SECONDS=10


# ==============================================================================
# BROWSER TOOL (requires Playwright)
# ==============================================================================
# The browser tool uses Playwright to render JavaScript-heavy pages.
#
# Installation (one-time, after pip install):
#   python -m playwright install chromium
#   # or: python -m playwright install --with-deps chromium
#
# If Playwright is not installed the tool returns a clear error message
# and falls back to the plain HTTP scraper for simple pages.

# Browser engine to use: chromium | firefox | webkit
PLAYWRIGHT_BROWSER=chromium

# Maximum seconds to wait for a page to fully load.
BROWSER_TIMEOUT=30

# Where to save screenshots captured by the browser tool.
BROWSER_SCREENSHOT_DIR=data/cache/screenshots
